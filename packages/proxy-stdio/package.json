  "devDependencies": {
    "@knotrust/approval": "workspace:*",
    "@knotrust/grants": "workspace:*",
    "@knotrust/test-harness": "workspace:*",
    "typescript": "catalog:",
    "@types/node": "catalog:",
    "vitest": "catalog:",
    "ajv": "catalog:",
    "ajv-formats": "catalog:"
  }
