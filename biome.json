{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "root": true,
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "packages/**",
      "test/**",
      "!**/dist",
      "!**/node_modules",
      "!**/*.md",
      "!docs",
      "!golden-vectors"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  }
}
